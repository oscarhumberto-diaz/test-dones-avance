{
    "name": "avance/test-dones",
    "type": "project",
    "description": "MVP Test de Dones Espirituales (AVANCE 2020)",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "dev": [
            "php artisan serve",
            "npm run dev"
        ],
        "test": [
            "@php artisan test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
